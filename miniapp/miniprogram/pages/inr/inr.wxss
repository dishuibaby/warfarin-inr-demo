.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f6f8fb;
  box-sizing: border-box;
}

.card,
.prompt-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.label {
  color: #64748b;
  font-size: 26rpx;
}

.target {
  margin-top: 10rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 800;
}

.legend,
.record,
.curve-row {
  margin-top: 18rpx;
  color: #475569;
  font-size: 26rpx;
}

.raw-dot,
.corrected-dot {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  margin: 0 8rpx 0 20rpx;
  border-radius: 50%;
}

.raw-dot {
  background: #94a3b8;
}

.corrected-dot {
  background: #0f766e;
}

.curve-row {
  display: flex;
  justify-content: space-between;
}

.weak {
  color: #94a3b8;
}

.prompt-card {
  color: #92400e;
  background: #fffbeb;
  font-size: 30rpx;
  line-height: 1.5;
}
