<view class="page">
  <view class="card">
    <view class="label">默认检测方式</view>
    <picker mode="selector" range="{{methodOptions}}" range-key="label" value="{{methodIndex}}" bindchange="onMethodChange">
      <view class="picker-value">{{methodOptions[methodIndex].label}}</view>
    </picker>
  </view>

  <view class="card">
    <view class="label">INR 校正偏移</view>
    <input class="input" type="digit" value="{{offsetInput}}" bindinput="onOffsetInput" placeholder="例如 0.05" />
  </view>

  <view class="card">
    <view class="label">检测周期</view>
    <input class="input" type="number" value="{{cycleValueInput}}" bindinput="onCycleValueInput" placeholder="周期数" />
    <picker mode="selector" range="{{cycleOptions}}" range-key="label" value="{{cycleIndex}}" bindchange="onCycleUnitChange">
      <view class="picker-value">单位：{{cycleOptions[cycleIndex].label}}</view>
    </picker>
  </view>

  <view class="card muted">
    <view class="label">可用检测方式</view>
    <view>静脉血、指尖血、家用仪检测</view>
  </view>

  <button class="primary-button" bindtap="onSave">保存设置</button>
</view>
