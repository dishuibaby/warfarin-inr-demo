.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f6f8fb;
  box-sizing: border-box;
}

.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.label {
  margin-bottom: 16rpx;
  color: #64748b;
  font-size: 26rpx;
}

.input,
.picker-value {
  min-height: 72rpx;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
}

.muted {
  color: #64748b;
  font-size: 26rpx;
}

.primary-button {
  margin: 0;
  border-radius: 999rpx;
  color: #ffffff;
  background: #0f766e;
  font-weight: 700;
}
